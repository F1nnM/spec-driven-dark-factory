FROM oven/bun:1

# Install git (repo operations) and Node.js (needed for Claude Code CLI)
RUN apt-get update && apt-get install -y git nodejs npm && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code
WORKDIR /app
COPY package.json bun.lock* ./
COPY packages/shared/package.json packages/shared/package.json
COPY services/frontend/package.json services/frontend/package.json
COPY services/agent/package.json services/agent/package.json
RUN bun install
COPY packages/shared/ packages/shared/
COPY services/agent/ services/agent/
WORKDIR /app/services/agent
EXPOSE 3001
CMD ["bun", "run", "src/index.ts"]
